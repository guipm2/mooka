# OPENAI_API_KEY: Required for OpenAI API calls.
# Keep this key only on the server side.
OPENAI_API_KEY="sk-proj-..."

# OPENAI_STRATEGY_MODEL: Model for brand strategy text generation.
OPENAI_STRATEGY_MODEL="gpt-4.1-mini"

# OPENAI_IMAGE_MODEL: Model for logo and mockup image generation.
OPENAI_IMAGE_MODEL="gpt-image-1"

# ALLOWED_ORIGINS: Comma-separated origins allowed by CORS in production.
ALLOWED_ORIGINS="https://mooka.com,https://app.mooka.com"

# REQUIRE_AUTH: If true, /api strategy/logo/mockup require a valid Supabase bearer token.
REQUIRE_AUTH="true"

# SUPABASE_URL and SUPABASE_ANON_KEY: Used on server only when REQUIRE_AUTH=true.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPABASE_URL: Your Supabase project URL (public frontend config).
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase anonymous API key (public frontend key).
VITE_SUPABASE_ANON_KEY="your-anon-key"
